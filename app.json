// app.js

const express = require('express');
const path = require('path');
const {
    default: makeWASocket,
    useMultiFileAuthState,
    makeInMemoryStore,
    Browsers,
    delay
} = require('@whiskeysockets/baileys');
const pino = require('pino'); // For logging
const fs = require('fs');

// --- Configuration ---
// These values will be read from Render's environment variables.
// Defaults are provided for local development if not set.
const PORT = process.env.PORT || 3000;
const SESSION_DIR = process.env.SESSION_DIR || 'session'; // Directory to store session files
const DEV_PHONE_NUMBER = process.env.DEV_PHONE_NUMBER || '254115172722'; // Your specified dev number
const BOT_NAME = process.env.BOT_NAME || '𝐁𝐥𝐚𝐜𝐤 𝐁𝐞𝐥𝐭𝐚𝐡'; // Your specified bot name (Unicode bold)
const PREFIX = process.env.PREFIX || '.'; // Default prefix from app.json
const MODE = process.env.MODE || 'PUBLIC'; // Bot mode from app.json

// Ensure session directory exists for Baileys
if (!fs.existsSync(SESSION_DIR)) {
    fs.mkdirSync(SESSION_DIR, { recursive: true });
}

// --- Baileys WhatsApp Client Setup ---
const logger = pino({ level: 'silent' }); // Set to 'info' for more verbose logging during development
const store = makeInMemoryStore({ logger }); // In-memory store for messages

let sock; // WhatsApp socket instance
let currentPairCode = null; // To store the 8-character pair code
let botIsConnected = false; // Bot connection status

async function connectToWhatsApp() {
    console.log(`[${BOT_NAME}] Starting WhatsApp connection...`);

    const { state, saveCreds } = await useMultiFileAuthState(SESSION_DIR);

    sock = makeWASocket({
        logger,
        printQRInTerminal: false, // Don't print QR in terminal, we use pair code on the web
        browser: Browsers.macOS('Desktop'), // Simulate a desktop browser for stable connection
        auth: {
            creds: state.creds,
            keys: state.keys
        },
        generateHighQualityLinkPreview: true,
        // shouldIgnoreJid: (jid) => jid.endsWith('@g.us') // Uncomment to ignore group messages by default
    });

    store.bind(sock.ev); // Bind Baileys store to socket events for message/contact handling

    // --- Baileys Event Handling ---
    sock.ev.on('connection.update', async (update) => {
        const { connection, lastDisconnect, code } = update;

        if (connection === 'close') {
            const shouldReconnect = lastDisconnect?.error?.output?.statusCode !== 401; // 401 means logged out
            console.log(`[${BOT_NAME}] Connection closed. Reason: ${lastDisconnect?.error?.message || 'Unknown'}. Reconnecting: ${shouldReconnect}`);
            botIsConnected = false;
            currentPairCode = null; // Clear pair code on disconnect

            if (lastDisconnect?.error?.output?.statusCode === 401) {
                console.log(`[${BOT_NAME}] Logged out. Deleting session and restarting.`);
                try {
                    fs.rmSync(SESSION_DIR, { recursive: true, force: true }); // Delete session folder
                    console.log(`[${BOT_NAME}] Session folder deleted.`);
                } catch (error) {
                    console.error(`[${BOT_NAME}] Error deleting session folder:`, error);
                }
                await delay(2000); // Give a moment before reconnecting
                connectToWhatsApp(); // Reconnect fresh
            } else if (shouldReconnect) {
                await delay(3000); // Short delay before attempting reconnect
                connectToWhatsApp(); // Reconnect
            }
        } else if (connection === 'open') {
            console.log(`[${BOT_NAME}] Connection opened! Bot is ready.`);
            botIsConnected = true;
            currentPairCode = null; // Clear pair code once connected
            // Send a welcome message to the DEV number once connected
            if (DEV_PHONE_NUMBER && DEV_PHONE_NUMBER !== '') {
                try {
                    await sock.sendMessage(DEV_PHONE_NUMBER + "@s.whatsapp.net", { text: `👋 ${BOT_NAME} is now online and connected!` });
                    console.log(`[${BOT_NAME}] Sent welcome message to dev number.`);
                } catch (e) {
                    console.error(`[${BOT_NAME}] Failed to send welcome message to dev number:`, e);
                }
            }
        } else if (code) { // This is the 8-character pair code for phone number linking
            currentPairCode = code;
            console.log(`[${BOT_NAME}] Pair Code received: ${currentPairCode}`);
            botIsConnected = false; // Not yet connected, waiting for pair
        }
    });

    sock.ev.on('creds.update', saveCreds); // Save credentials whenever they update

    // --- Message Handling (Basic Example) ---
    sock.ev.on('messages.upsert', async (m) => {
        const msg = m.messages[0];
        if (!msg.message) return; // Ignore empty messages
        if (msg.key.fromMe) return; // Ignore messages from myself

        const senderJid = msg.key.remoteJid;
        const text = msg.message.extendedTextMessage?.text || msg.message.conversation || msg.message.imageMessage?.caption || msg.message.videoMessage?.caption || '';

        console.log(`[${BOT_NAME}] Received message from ${senderJid}: "${text}"`);

        // Simple command examples
        if (text.startsWith(PREFIX + 'echo ')) {
            const replyText = text.substring((PREFIX + 'echo ').length).trim();
            await sock.sendMessage(senderJid, { text: `Echo: ${replyText}` }, { quoted: msg });
        } else if (text.toLowerCase() === PREFIX + 'ping') {
             await sock.sendMessage(senderJid, { text: 'Pong!' }, { quoted: msg });
        }
        // Add more complex bot logic here (e.g., sticker commands, group management)
    });
}

// Start WhatsApp connection when the server starts
connectToWhatsApp();

// --- Express Web Server ---
const app = express();

// Serve static files from the 'public' directory
app.use(express.static(path.join(__dirname, 'public')));

// Route to serve the main HTML file for the pair page
app.get('/', (req, res) => {
    res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

// API endpoint to get the 8-character pair code
app.get('/getPairCode', (req, res) => {
    if (botIsConnected) {
        res.status(200).json({ code: 'CONNECTED', message: 'Bot is already linked.' });
    } else if (currentPairCode) {
        res.json({ code: currentPairCode });
    } else {
        res.status(202).json({ code: 'WAITING', message: 'Pair code not yet generated. Please wait and refresh.' });
    }
});

// API endpoint to check the bot's connection status
app.get('/status', (req, res) => {
    res.json({ connected: botIsConnected });
});

// Dynamic /set.js route to provide bot settings to the frontend
app.get('/set.js', (req, res) => {
    const settings = {
        botname: BOT_NAME,
        mode: MODE,
        prefix: PREFIX
    };
    // Send as a JavaScript file that exports a JSON object
    res.type('application/javascript');
    res.send(`module.exports = ${JSON.stringify(settings)};`);
});

// Start the Express server and listen for incoming requests
app.listen(PORT, () => {
    console.log(`Server running on http://localhost:${PORT}`);
    console.log(`Access the pair page at http://localhost:${PORT}`);
    console.log(`[${BOT_NAME}] Bot initialized. Waiting for connection...`);
});
